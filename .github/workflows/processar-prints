name: Processar Prints e Atualizar Dashboard

on:
  push:
    paths:
      - 'imagens/**' # Só roda se você adicionar ou mexer em algo na pasta de imagens

permissions:
  contents: write
  pages: write
  id-token: write

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout do código
        uses: actions/checkout@v4

      - name: Configurar Node.js
        uses: actions/setup-node@v4
        with:
          node-index: '20'

      - name: Instalar Dependências
        run: npm install

      - name: Rodar a Inteligência Artificial
        env:
          IA_API_KEY: ${{ secrets.IA_API_KEY }} # Sua chave protegida nos Secrets do GitHub
        run: node processar.js

      - name: Commitar dados.json atualizado
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: "🤖 [Bot] Atualiza dados.json com novos prints processados"
          file_pattern: 'dados.json'

      - name: Configurar GitHub Pages
        uses: actions/configure-pages@v4

      - name: Upload do Site Estático
        uses: actions/upload-pages-artifact@v3
        with:
          path: '.' # Sobe a raiz do projeto (incluindo o novo dados.json e o index.html)

      - name: Deploy para o GitHub Pages
        uses: actions/deploy-pages@v4
